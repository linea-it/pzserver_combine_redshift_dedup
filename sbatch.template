#!/bin/bash

#SBATCH --job-name={jobname}
#SBATCH --chdir={cwd}
#SBATCH --account=hpc-pipelines
#SBATCH --time=04:00:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=48G
#SBATCH --output={out}
#SBATCH --error={err}
#SBATCH --partition=cpu_pipelines
#SBATCH --propagate

{cmd} .
status=$?

echo "$status" > return.code
echo "Done with exit code $status"

exit "$status"
